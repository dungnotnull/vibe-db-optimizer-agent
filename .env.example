# vibe-db-optimizer-agent — Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────

# PostgreSQL connection (read-only user recommended)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://optimizer_readonly:changeme@localhost:5432/vibe_db

# MySQL connection (read-only user recommended)
# Format: mysql://user:password@host:3306/dbname
MYSQL_URL=mysql://optimizer_readonly:changeme@localhost:3306/vibe_db

# Anthropic API key for DBA analysis
ANTHROPIC_API_KEY=sk-ant-...


# ── Optional ───────────────────────────────────────────

# ChromaDB storage path (default: ./data/chroma)
# CHROMA_DB_PATH=./data/chroma

# Python ML microservice URL (default: http://localhost:8000)
# PYTHON_ML_SERVICE_URL=http://localhost:8000

# Knowledge brain file path (default: ./SECOND-KNOWLEDGE-BRAIN.md)
# KNOWLEDGE_BRAIN_PATH=./SECOND-KNOWLEDGE-BRAIN.md

# Results output directory (default: ./results)
# RESULTS_DIR=./results

# Log level (debug, info, warn, error)
# LOG_LEVEL=info

# Maximum DB connections in pool
# DB_POOL_MAX=5

# LLM model to use
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LLM max tokens per analysis call
# LLM_MAX_TOKENS=800

# LLM temperature (lower = more deterministic)
# LLM_TEMPERATURE=0.1
